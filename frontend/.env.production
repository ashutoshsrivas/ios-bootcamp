# Production build config for https://iosdc.geu.ac.in/bootcamp
# These are PUBLIC values (baked into the client bundle) — no secrets here.
NEXT_PUBLIC_BASE_PATH=/bootcamp
# api.js sends requests to `${NEXT_PUBLIC_API_BASE}/api/...`, so this must NOT include /api.
NEXT_PUBLIC_API_BASE=https://iosdc.geu.ac.in/bootcamp
